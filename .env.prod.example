# ══════════════════════════════════════════════════════════════════════════════
#  Congreso Ingenierías 2026 — Variables de entorno de PRODUCCIÓN
#  Copiar este archivo a .env y completar los valores secretos.
#  NUNCA subir el .env real al repositorio Git.
# ══════════════════════════════════════════════════════════════════════════════

# URL pública del sitio (sin barra al final)
APP_URL=http://congreso2026.bucaramanga.upb.edu.co

# Dominio para sesiones de Sanctum (solo el dominio, sin http://)
SANCTUM_STATEFUL_DOMAINS=congreso2026.bucaramanga.upb.edu.co

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_DATABASE=congreso_db
DB_USERNAME=congreso
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_ROOT_PASSWORD=CAMBIAR_POR_ROOT_PASSWORD_SEGURO
