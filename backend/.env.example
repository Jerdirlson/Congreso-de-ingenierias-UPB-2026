APP_NAME="Congreso Ingenierias 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database (Docker: MySQL | Local: SQLite) ─────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=congreso_db
DB_USERNAME=congreso
DB_PASSWORD=secret

# ── Cache / Sessions / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
# Opción A: Mailpit (captura en http://localhost:8025, no envía a correo real)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# Opción B: Gmail (envía correos reales) - descomenta y reemplaza:
# 1. Activa 2FA en tu cuenta Google
# 2. Crea contraseña de app: https://myaccount.google.com/apppasswords
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-correo@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="noreply@congreso.edu.co"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:4173,localhost:3000

# ── Media Library ─────────────────────────────────────────────────────────────
MEDIA_DISK=public

# ── Cloudflare Stream ────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# ── Anthropic (Claude API) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_CONFIDENCE_THRESHOLD=70

# ── Admin (seeder) ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@congreso.upb.edu.co
ADMIN_PASSWORD=Congreso2026!

VITE_APP_NAME="${APP_NAME}"
